# Скопируйте в `.env` и при необходимости поправьте значения.
# Docker Compose подхватывает этот файл автоматически для подстановки в `docker-compose.yml`.

# =============================================================================
# Docker Compose — порты и время остановки
# =============================================================================
GATEWAY_PORT=8080
WEB_PORT=8081
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
GATEWAY_STOP_GRACE_PERIOD=40s

# =============================================================================
# PostgreSQL (сервис postgres; URL для приложений в compose собирается из этих полей)
# =============================================================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=app

# Локальный запуск `go run` / `python` вне Docker — хост `localhost`. В `docker compose` URL для gateway/runner собирается из POSTGRES_* (см. `docker-compose.yml`), это значение контейнеры не читают.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/app?sslmode=disable

# =============================================================================
# Redis
# =============================================================================
REDIS_URL=redis://redis:6379/0
REDIS_AUDIO_QUEUE_KEY=tulahack:queue:audio:process
REDIS_BRPOP_TIMEOUT_SEC=5
# Опционально (шлюз): если не заданы — используются значения по умолчанию в коде
REDIS_JOB_STATUS_KEY_PREFIX=
REDIS_JOB_EVENTS_CHANNEL_PREFIX=

# =============================================================================
# S3 / MinIO (учётные данные совпадают с MinIO_ROOT_* в контейнере minio)
# =============================================================================
S3_ENDPOINT=minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin123
S3_BUCKET=app
S3_USE_SSL=false
# URL MinIO для ссылок в API (без завершающего /), доступный браузеру клиента.
# Локально (прямой порт MinIO): http://127.0.0.1:9000
# Прод (system nginx проксирует https://<домен>/minio/ -> :9000)
S3_PUBLIC_BASE_URL=http://127.0.0.1:9000

# =============================================================================
# Шлюз (Go, сервис gateway)
# =============================================================================
GATEWAY_ADDR=:8080
GATEWAY_LOG_VERBOSE=1
SHUTDOWN_TIMEOUT_SEC=30
JWT_SECRET=change-me-dev-only-min-32-chars-please
JWT_ACCESS_TTL_SEC=900
JWT_REFRESH_TTL_SEC=604800

# =============================================================================
# Runner (Python) — HTTP-воркеры на хосте или в сети
# =============================================================================
STT_BASE_URL=http://127.0.0.1:8001
LLM_BASE_URL=http://127.0.0.1:8081
REDACT_BASE_URL=http://127.0.0.1:8082
STT_HTTP_TIMEOUT_SEC=600
LLM_HTTP_TIMEOUT_SEC=120
REDACT_HTTP_TIMEOUT_SEC=600
HTTP_MAX_ATTEMPTS=5
HTTP_RETRY_BASE_SEC=1.0
WORKER_QUEUE_RETRIES=4
LOG_LEVEL=info
# Общий секрет с воркерами STT/LLM/Redact (`Authorization: Bearer …`); в проде сгенерируйте случайную строку
WORKER_TOKEN=

# =============================================================================
# Исходящий HTTP(S) через прокси (gateway и runner; пусто = как в compose по умолчанию)
# =============================================================================
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=postgres,redis,minio,gateway,web,runner,127.0.0.1,localhost
