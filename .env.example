# --- Шлюз (Go) ---
GATEWAY_ADDR=:8080
SHUTDOWN_TIMEOUT_SEC=30
GATEWAY_LOG_VERBOSE=
DATABASE_URL=
JWT_SECRET=
JWT_ACCESS_TTL_SEC=900
JWT_REFRESH_TTL_SEC=604800

# Redis
REDIS_URL=
REDIS_AUDIO_QUEUE_KEY=
REDIS_JOB_EVENTS_CHANNEL_PREFIX=

# S3 / MinIO
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=app
S3_USE_SSL=false
# Базовый URL MinIO для ссылок в API (без завершающего /). На сервере укажите адрес, доступный браузеру клиента
S3_PUBLIC_BASE_URL=http://127.0.0.1:9000

# --- Runner (Python) — см. backend/runner/README.md ---
STT_BASE_URL=
LLM_BASE_URL=
REDACT_BASE_URL=
# Общий секрет с воркерами STT/LLM/Redact; сгенерируйте длинную случайную строку
WORKER_TOKEN=

HTTP_MAX_ATTEMPTS=5
HTTP_RETRY_BASE_SEC=1.0
WORKER_QUEUE_RETRIES=4

STT_HTTP_TIMEOUT_SEC=600
LLM_HTTP_TIMEOUT_SEC=120
REDACT_HTTP_TIMEOUT_SEC=600

# --- docker compose: опционально исходящий HTTP(S) через прокси ---
# Раскомментируйте при необходимости (например, если воркеры доступны только через прокси).
# HTTP_PROXY=http://proxy.example.com:8080
# HTTPS_PROXY=http://proxy.example.com:8080
# NO_PROXY=postgres,redis,minio,gateway,web,runner,127.0.0.1,localhost
